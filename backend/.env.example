# ── Required ──────────────────────────────────────────────────────────────────
# BIP-39 mnemonic — same value used by the indexer for address derivation.
# Generate once with: go run github.com/tyler-smith/go-bip39/...
# or any BIP-39 generator. NEVER reuse a mainnet mnemonic here.
MASTER_MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# PostgreSQL — same instance shared with the indexer and dispatcher.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# RabbitMQ — message broker for the order queue.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=8081
ENV=development

# URL the dispatcher will POST webhooks to.
# If indexer + dispatcher + b2b-merchant all run locally, the default works.
WEBHOOK_URL=http://localhost:8081/webhook

# ── Nomba API (Global Payout) ─────────────────────────────────────────────────
# Required for exchange rate fetching. Get these from your Nomba dashboard.
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
